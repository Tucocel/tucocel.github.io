<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TUCOCEL POS — Centro de Control y Facturación</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="bg-slate-950 text-slate-100 min-h-screen transition-all duration-300">

    <!-- PANTALLA CENTRAL: VISTA ADMIN (EL NETFLIX DE TUCOCEL) -->
    <div id="vista-master-admin" class="p-4 sm:p-8 max-w-7xl mx-auto space-y-6">
        
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 border-b border-slate-800 pb-5">
            <div>
                <span class="bg-blue-500/10 text-blue-400 border border-blue-500/20 text-[10px] font-bold tracking-widest uppercase px-3 py-1 rounded-full inline-flex items-center gap-1.5">
                    <i class="fa-solid fa-user-shield text-[11px]"></i> Panel Supremo de Control
                </span>
                <h1 class="text-2xl font-black tracking-tight text-white mt-2 flex items-center gap-2">
                    TUCOCEL MÁSTER CONTROL <span class="text-amber-400">🔒</span>
                </h1>
                <p class="text-slate-400 text-xs font-medium mt-1">Administración centralizada optimizada para Móvil y PC.</p>
            </div>
            <div class="flex items-center gap-3 bg-slate-900 border border-slate-800 p-2.5 rounded-2xl text-xs font-bold font-mono w-full sm:w-auto justify-between sm:justify-start">
                <div class="text-center px-2 border-r border-slate-800 flex-grow sm:flex-grow-0">
                    <span class="block text-[9px] text-slate-500 uppercase tracking-wider">Clientes</span>
                    <span id="global-clientes-count" class="text-blue-400 text-base font-black">2</span>
                </div>
                <div class="text-center px-2 flex-grow sm:flex-grow-0">
                    <span class="block text-[9px] text-slate-500 uppercase tracking-wider">Servidor</span>
                    <span class="text-emerald-400 text-base font-black flex items-center justify-center gap-1">ONLINE <span class="w-2 h-2 rounded-full bg-emerald-400 animate-ping"></span></span>
                </div>
            </div>
        </div>

        <div class="space-y-4">
            <h2 class="text-xs font-extrabold uppercase tracking-widest text-slate-400 px-1">¿Qué perfil deseas gestionar hoy?</h2>
            <div id="mosaico-clientes-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 pt-1">
                
                <div id="card-demo-1" class="bg-slate-900 border border-slate-800/80 rounded-3xl p-5 flex flex-col justify-between hover:border-blue-500/40 transition-all group relative overflow-hidden">
                    <div class="absolute top-4 right-4 flex items-center gap-1.5 z-10">
                        <span class="w-2.5 h-2.5 rounded-full bg-emerald-400 shadow-[0_0_8px_rgba(52,211,153,0.5)]"></span>
                    </div>
                    <div>
                        <div class="w-14 h-14 bg-slate-950 border border-slate-800 rounded-2xl flex items-center justify-center p-2 mb-3 overflow-hidden shadow-inner">
                            <i class="fa-solid fa-mobile-screen text-xl text-blue-500"></i>
                        </div>
                        <h3 class="font-black text-white text-base tracking-tight group-hover:text-blue-400 transition-colors">City Móvil</h3>
                        <p class="text-[9px] text-slate-500 font-bold font-mono tracking-wider mt-0.5 uppercase">ID: citymovil</p>
                        
                        <div class="mt-3 space-y-1 bg-slate-950/60 p-3 rounded-xl border border-slate-850 text-xs font-medium text-slate-400">
                            <p class="flex justify-between font-mono"><span class="text-slate-500">Suscripción:</span> <span class="text-slate-300 font-bold" id="label-dias-card-demo-1">365 Días</span></p>
                            <p class="flex justify-between font-mono"><span class="text-slate-500">Estado:</span> <span class="text-emerald-400 font-bold" id="label-status-card-demo-1">Activo</span></p>
                        </div>
                    </div>
                    <div class="mt-5 pt-3 border-t border-slate-800/60 flex gap-2">
                        <button onclick="abrirConfiguracionCliente('demo-1', 'City Móvil', 'V-20123456', '04141234567', 'Cordero, Centro', '@citymovil', 'Garantía estándar de 2 meses por defectos de fábrica.', 'citymovil', 'Razu2026.', '365')" class="w-1/2 bg-slate-800 text-slate-200 text-xs font-bold py-2.5 rounded-xl">Configurar</button>
                        <button onclick="forzarEntradaClienteDirecta('City Móvil', 'Garantía estándar de 2 meses por defectos de fábrica.', 365)" class="w-1/2 bg-blue-600 text-white text-xs font-black py-2.5 rounded-xl uppercase tracking-wider">Entrar</button>
                    </div>
                </div>

                <div id="card-demo-2" class="bg-slate-900 border border-slate-800/80 rounded-3xl p-5 flex flex-col justify-between hover:border-red-500/40 transition-all group relative overflow-hidden">
                    <div class="absolute top-4 right-4 flex items-center gap-1.5 z-10">
                        <span class="w-2.5 h-2.5 rounded-full bg-red-500 animate-pulse shadow-[0_0_8px_rgba(239,68,68,0.5)]"></span>
                    </div>
                    <div>
                        <div class="w-14 h-14 bg-slate-950 border border-slate-800 rounded-2xl flex items-center justify-center p-2 mb-3 overflow-hidden shadow-inner">
                            <i class="fa-solid fa-shop text-xl text-amber-500"></i>
                        </div>
                        <h3 class="font-black text-white text-base tracking-tight group-hover:text-amber-400 transition-colors">Frigorífico Don Luis</h3>
                        <p class="text-[9px] text-slate-500 font-bold font-mono tracking-wider mt-0.5 uppercase">ID: donluis</p>
                        
                        <div class="mt-3 space-y-1 bg-slate-950/60 p-3 rounded-xl border border-slate-850 text-xs font-medium text-slate-400">
                            <p class="flex justify-between font-mono"><span class="text-slate-500">Suscripción:</span> <span class="text-red-400 font-bold" id="label-dias-card-demo-2">12 Días</span></p>
                            <p class="flex justify-between font-mono"><span class="text-slate-500">Estado:</span> <span class="text-red-400 font-bold uppercase text-[10px]" id="label-status-card-demo-2">Por Vencer</span></p>
                        </div>
                    </div>
                    <div class="mt-5 pt-3 border-t border-slate-800/60 flex gap-2">
                        <button onclick="abrirConfiguracionCliente('demo-2', 'Frigorífico Don Luis', 'J-31234567', '04247654321', 'Avenida Bolívar, Cordero', '@frigonluis', 'No se aceptan cambios en productos cárnicos una vez retirados.', 'donluis', 'Luis2026', '12')" class="w-1/2 bg-slate-800 text-slate-200 text-xs font-bold py-2.5 rounded-xl">Configurar</button>
                        <button onclick="forzarEntradaClienteDirecta('Frigorífico Don Luis', 'No se aceptan cambios en productos cárnicos una vez retirados.', 12)" class="w-1/2 bg-blue-600 text-white text-xs font-black py-2.5 rounded-xl uppercase tracking-wider">Entrar</button>
                    </div>
                </div>

                <button onclick="abrirModalCrearPerfil()" class="bg-slate-900/40 border-2 border-dashed border-slate-800 hover:border-blue-500/50 hover:bg-slate-900 rounded-3xl p-5 flex flex-col items-center justify-center min-h-[200px] transition-all group gap-2 text-center">
                    <div class="w-12 h-12 bg-slate-950 rounded-full border border-slate-800 flex items-center justify-center text-slate-500 group-hover:text-blue-400 transition-all">
                        <i class="fa-solid fa-plus text-lg"></i>
                    </div>
                    <div>
                        <span class="block font-black text-slate-400 group-hover:text-white text-sm tracking-wide">Crear Perfil</span>
                        <span class="block text-[10px] text-slate-600 font-medium mt-0.5">Añadir nuevo comercio</span>
                    </div>
                </button>

            </div>
        </div>
    </div>

    <!-- MODAL CONFIGURACIÓN MÁSTER -->
    <div id="modal-config-master" class="fixed inset-0 bg-slate-950/95 backdrop-blur-md z-50 p-3 overflow-y-auto hidden flex items-center justify-center">
        <div class="bg-slate-900 border border-slate-800 w-full max-w-lg rounded-3xl overflow-hidden shadow-2xl flex flex-col">
            
            <div class="bg-slate-950 px-5 py-3.5 border-b border-slate-800 flex justify-between items-center">
                <div class="flex items-center gap-2">
                    <i class="fa-solid fa-sliders text-amber-400 text-base"></i>
                    <div>
                        <h3 id="cfg-modal-titulo" class="font-black text-xs uppercase tracking-wider text-white">Configurar Cliente</h3>
                        <p class="text-[9px] text-slate-500 font-mono">GESTIÓN INTERNA DE LICENCIAS</p>
                    </div>
                </div>
                <button onclick="cerrarConfiguracionCliente()" class="text-slate-500 hover:text-white bg-slate-950 w-8 h-8 rounded-xl flex items-center justify-center border border-slate-800"><i class="fa-solid fa-xmark"></i></button>
            </div>

            <div class="p-4 space-y-5 max-h-[70vh] overflow-y-auto no-scrollbar">
                
                <div class="space-y-3">
                    <h4 class="text-[9px] font-black text-blue-400 uppercase tracking-widest border-b border-slate-800 pb-1"><i class="fa-solid fa-address-card"></i> Datos Comerciales</h4>
                    <div class="flex items-center gap-3 p-3 bg-slate-950 border border-slate-850 rounded-xl">
                        <input type="file" id="cfg-logo-file" accept="image/*" class="hidden" onchange="previewImageDemo(event)">
                        <div onclick="document.getElementById('cfg-logo-file').click()" class="w-12 h-12 bg-slate-900 border border-slate-800 rounded-xl flex items-center justify-center overflow-hidden shrink-0 cursor-pointer">
                            <img id="cfg-logo-preview" src="" class="w-full h-full object-contain hidden">
                            <i id="cfg-logo-placeholder" class="fa-solid fa-camera text-slate-600"></i>
                        </div>
                        <span class="text-[10px] text-slate-400 font-bold">Toque el recuadro para subir logo del local</span>
                    </div>
                    <div class="space-y-2">
                        <input type="text" id="cfg-nombre" placeholder="Nombre Comercial" class="w-full bg-slate-950 border border-slate-800 p-2.5 rounded-xl text-xs font-bold text-white focus:outline-none focus:border-blue-500">
                        <input type="text" id="cfg-rif" placeholder="Cédula o RIF" class="w-full bg-slate-950 border border-slate-800 p-2.5 rounded-xl text-xs font-bold text-white focus:outline-none focus:border-blue-500">
                        <div class="grid grid-cols-2 gap-2">
                            <input type="text" id="cfg-tlf" placeholder="WhatsApp" class="w-full bg-slate-950 border border-slate-800 p-2.5 rounded-xl text-xs font-bold text-white focus:outline-none focus:border-blue-500">
                            <input type="text" id="cfg-redes" placeholder="Instagram" class="w-full bg-slate-950 border border-slate-800 p-2.5 rounded-xl text-xs font-bold text-white focus:outline-none focus:border-blue-500">
                        </div>
                        <input type="text" id="cfg-dir" placeholder="Dirección del Local" class="w-full bg-slate-950 border border-slate-800 p-2.5 rounded-xl text-xs font-bold text-white focus:outline-none focus:border-blue-500">
                    </div>
                </div>

                <div class="space-y-3">
                    <h4 class="text-[9px] font-black text-amber-400 uppercase tracking-widest border-b border-slate-800 pb-1"><i class="fa-solid fa-code-branch"></i> Seguridad y Texto</h4>
                    <div class="space-y-2">
                        <input type="text" id="cfg-user" disabled placeholder="ID de Usuario" class="w-full bg-slate-950/50 border border-slate-850 p-2.5 rounded-xl text-xs font-bold text-slate-500 font-mono cursor-not-allowed">
                        <input type="text" id="cfg-pass" placeholder="Contraseña de Acceso" class="w-full bg-slate-950 border border-slate-800 p-2.5 rounded-xl text-xs font-bold text-white font-mono focus:outline-none focus:border-amber-500">
                        <textarea id="cfg-garantia" placeholder="Escribe aquí los términos de garantía..." class="w-full bg-slate-950 border border-slate-800 p-2.5 rounded-xl text-xs font-medium text-white h-20 resize-none focus:outline-none focus:border-blue-500"></textarea>
                    </div>
                </div>

                <div class="space-y-3">
                    <h4 class="text-[9px] font-black text-purple-400 uppercase tracking-widest border-b border-slate-800 pb-1"><i class="fa-solid fa-lock"></i> Licencia (Fijar Plazo - No Suma)</h4>
                    <div class="bg-slate-950 p-3 rounded-xl border border-slate-850 space-y-2">
                        <div class="grid grid-cols-3 gap-1.5">
                            <button onclick="asignarDiasSimulador(30, this)" class="tiempo-btn bg-slate-900 border border-slate-800 text-slate-300 text-[10px] py-2 font-bold rounded-lg transition-all">1 Mes</button>
                            <button onclick="asignarDiasSimulador(180, this)" class="tiempo-btn bg-slate-900 border border-slate-800 text-slate-300 text-[10px] py-2 font-bold rounded-lg transition-all">6 Meses</button>
                            <button onclick="asignarDiasSimulador(365, this)" class="tiempo-btn bg-slate-900 border border-slate-800 text-slate-300 text-[10px] py-2 font-bold rounded-lg transition-all">1 Año</button>
                        </div>
                        <div class="pt-1.5 flex justify-between items-center text-xs font-bold font-mono">
                            <span class="text-slate-500">Plazo Seleccionado:</span>
                            <span id="cfg-dias-display" class="text-amber-400 font-black">365 Días</span>
                        </div>
                    </div>
                    <div class="space-y-1.5">
                        <div class="flex gap-2">
                            <input type="text" id="cfg-link-url" readonly value="" class="w-full bg-slate-950 border border-slate-850 p-2 rounded-xl text-[10px] font-mono text-blue-400 truncate focus:outline-none">
                            <button onclick="copiarLinkPortapapelesDemo()" class="bg-slate-800 text-slate-200 px-3 text-xs font-bold rounded-xl border border-slate-700"><i class="fa-solid fa-copy"></i></button>
                        </div>
                        <button onclick="dispararContratoWhatsAppSimulado()" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-black py-2.5 rounded-xl shadow-lg flex items-center justify-center gap-1.5 uppercase transition-all">
                            <i class="fa-brands fa-whatsapp text-sm"></i> Visualizar Mensaje WhatsApp
                        </button>
                        <button id="cfg-btn-borrar" class="w-full bg-red-500/10 hover:bg-red-500/20 text-red-400 text-[10px] font-bold py-1.5 rounded-xl border border-red-500/20 uppercase transition-all">
                            <i class="fa-solid fa-trash-can mr-1"></i> Eliminar Perfil de Prueba
                        </button>
                    </div>
                </div>

            </div>
            
            <div class="bg-slate-950 px-4 py-3 border-t border-slate-800 flex justify-end gap-2">
                <button onclick="cerrarConfiguracionCliente()" class="bg-slate-800 text-slate-300 px-4 py-2 rounded-xl text-xs font-bold">Cerrar</button>
                <button onclick="guardarDatosClienteSimulados()" class="bg-amber-400 hover:bg-amber-500 text-slate-950 px-5 py-2 rounded-xl text-xs font-black uppercase shadow-md">Guardar Perfil</button>
            </div>
        </div>
    </div>

    <!-- MODAL PREVIA CONTRATO -->
    <div id="modal-whatsapp-preview" class="fixed inset-0 bg-slate-950/90 z-50 p-4 hidden flex items-center justify-center">
        <div class="bg-white text-gray-900 w-full max-w-sm rounded-3xl shadow-2xl overflow-hidden flex flex-col border border-gray-100">
            <div class="bg-emerald-600 px-4 py-3 text-white flex justify-between items-center font-bold text-xs uppercase tracking-wide">
                <span><i class="fa-brands fa-whatsapp text-sm mr-1"></i> Formato para WhatsApp</span>
                <button onclick="document.getElementById('modal-whatsapp-preview').classList.add('hidden')" class="bg-emerald-700 w-6 h-6 rounded-lg flex items-center justify-center text-white"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="p-4 bg-emerald-50 max-h-[50vh] overflow-y-auto font-mono text-xs text-emerald-950 text-left whitespace-pre-wrap leading-relaxed select-all" id="whatsapp-preview-content"></div>
            <div class="p-3 bg-gray-50 border-t border-gray-100 flex justify-end">
                <button onclick="document.getElementById('modal-whatsapp-preview').classList.add('hidden')" class="bg-emerald-600 text-white font-black text-xs px-5 py-2 rounded-xl shadow">Aceptar</button>
            </div>
        </div>
    </div>


    <!-- PANTALLA SECUNDARIA: ENTORNO CLIENTE -->
    <div id="vista-entorno-cliente" class="hidden min-h-screen bg-slate-50 text-slate-800 flex flex-col justify-between">
        
        <!-- LOGIN INDEPENDIENTE DEL COMERCIO -->
        <div id="cli-bloque-login" class="flex-grow flex flex-col items-center justify-center p-4">
            <div class="bg-white border border-slate-200 w-full max-w-sm rounded-3xl p-5 shadow-xl space-y-5">
                <div class="text-center space-y-2">
                    <div id="login-logo-dinamico" class="w-14 h-14 bg-blue-50 border border-blue-100 rounded-2xl flex items-center justify-center mx-auto text-blue-600 text-2xl font-bold p-1 overflow-hidden">
                        <i class="fa-solid fa-shop"></i>
                    </div>
                    <h2 id="login-titulo-dinamico" class="font-black text-lg text-slate-900 tracking-tight">Acceso Comercial</h2>
                    <span class="text-[9px] text-blue-600 font-extrabold tracking-widest uppercase bg-blue-50 px-3 py-1 rounded-full inline-block">Módulo POS Independiente</span>
                </div>
                <div class="space-y-2.5">
                    <input type="text" id="comercio-user-field" value="comercio_pos" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 rounded-xl text-xs font-bold focus:outline-none">
                    <input type="password" id="comercio-pass-field" value="12345" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 rounded-xl text-xs font-bold focus:outline-none">
                    <button onclick="desbloquearPantallaFacturacionReal()" class="w-full bg-blue-600 hover:bg-blue-700 text-white text-xs font-black py-3 rounded-xl uppercase tracking-wider transition-all">Ingresar al Sistema</button>
                </div>
                
                <div class="bg-amber-50/80 border border-amber-200 rounded-2xl p-4 flex gap-3 shadow-inner">
                    <i class="fa-solid fa-shield-halved text-amber-600 text-base mt-0.5 shrink-0"></i>
                    <div class="text-[11px] text-amber-900 leading-relaxed text-justify space-y-1">
                        <h4 class="font-black uppercase tracking-wider text-amber-950 flex items-center gap-1">Reglas de Oro del Sistema</h4>
                        <p>Este software opera estrictamente bajo la modalidad de <span class="font-bold text-amber-950">Servicio por Suscripción Alquilada</span>.</p>
                        <p>El usuario es el único responsable por los inventarios, montos de dinero y operaciones registradas. La plataforma emite comprobantes tipo <span class="font-bold text-amber-950">Nota de Entrega sin valor fiscal</span> destinados para el orden interno administrativo del comercio.</p>
                    </div>
                </div>

                <!-- LEYENDA DE AUTOR EN LOGIN COMERCIAL -->
                <div class="pt-4 border-t border-gray-150 text-center space-y-1">
                    <p class="text-[9px] text-gray-400 font-bold">© 2026 Tucocel C.A. Todos los derechos reservados.</p>
                    <p class="text-[9px] text-gray-500">Del sistema (SaaS) desarrollada de manera exclusiva por <span class="text-gray-700 font-extrabold">@publionlinemk</span> — Agencia Oficial de Publicidad de Tucocel C.A.</p>
                </div>
            </div>
        </div>

        <!-- ENTORNO DE CAJA OPERATIVO -->
        <div id="cli-bloque-sistema" class="hidden flex-grow flex flex-col">
            <div class="bg-white border-b border-slate-200 px-4 py-3 flex justify-between items-center sticky top-0 z-30 shadow-sm">
                <div class="flex items-center gap-2">
                    <div id="cli-panel-logo-box" class="w-9 h-9 bg-slate-900 border border-slate-200 rounded-xl flex items-center justify-center text-white p-1 font-bold text-sm overflow-hidden"><i class="fa-solid fa-shop"></i></div>
                    <div>
                        <h2 id="cli-panel-nombre" class="font-black text-slate-900 text-sm tracking-tight">Comercio</h2>
                        <span class="text-[9px] text-blue-600 font-extrabold uppercase block -mt-0.5">Facturación Activa</span>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <!-- CONTADOR DE MEMBRESÍA DINÁMICO INALTERABLE -->
                    <div id="contenedor-status-reloj" class="bg-gray-100 border border-gray-200 px-2.5 py-1 rounded-xl flex items-center gap-1 text-[10px] font-mono font-bold transition-all duration-300">
                        <i class="fa-solid fa-hourglass-half text-amber-500" id="cli-panel-icon-reloj"></i>
                        <span id="cli-panel-dias-conteo" class="text-slate-700 font-black">365 Días</span>
                    </div>
                    <button onclick="regresarAlMasterControlAdmin()" class="bg-slate-950 text-white font-extrabold text-[9px] px-2.5 py-1.5 rounded-lg uppercase">Salir</button>
                </div>
            </div>

            <div class="p-4 max-w-md mx-auto w-full space-y-4 flex-grow pb-24">
                
                <!-- ALERTA VISUAL INTEGRADA DE VENCIMIENTO -->
                <div id="banner-alerta-vencimiento" class="hidden rounded-2xl p-3.5 flex items-center gap-3 border shadow-sm transition-all duration-300">
                    <i id="banner-alerta-icono" class="fa-solid text-base shrink-0"></i>
                    <div class="text-[11px] leading-tight">
                        <h4 id="banner-alerta-titulo" class="font-black uppercase tracking-wider">Aviso del Sistema</h4>
                        <p id="banner-alerta-desc" class="font-medium mt-0.5 text-justify">Tu membresía administrativa se encuentra próxima a vencer.</p>
                    </div>
                </div>

                <div class="bg-slate-900 text-white rounded-2xl p-3 grid grid-cols-2 gap-2 text-center border border-slate-800 shadow-md">
                    <div class="border-r border-slate-800">
                        <span class="text-[9px] text-slate-400 uppercase font-bold block">Tasa COP</span>
                        <input type="number" id="tasa-cop" value="3900" class="w-full bg-transparent text-center font-black text-sm text-amber-400 focus:outline-none" onkeyup="calcularTotalesSimulados()">
                    </div>
                    <div>
                        <span class="text-[9px] text-slate-400 uppercase font-bold block">Tasa Bs</span>
                        <input type="number" id="tasa-bs" value="40" class="w-full bg-transparent text-center font-black text-sm text-emerald-400 focus:outline-none" onkeyup="calcularTotalesSimulados()">
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[9px] text-slate-400 uppercase font-black block tracking-wider px-1">Productos en Inventario (Toque para vender)</label>
                    <div class="grid grid-cols-2 gap-2">
                        <button onclick="agregarAlTicketSimulado('Vidrio Cerámico Privacidad', 5)" class="bg-white border border-slate-200 p-2.5 rounded-xl text-left hover:border-blue-500 transition-colors flex flex-col justify-between h-14 shadow-sm">
                            <span class="text-[10px] font-bold text-slate-800 truncate block w-full">Vidrio Privacidad</span>
                            <span class="text-xs font-black text-blue-600 font-mono">$5.00</span>
                        </button>
                        <button onclick="agregarAlTicketSimulado('Cargador Tipo C Carga Rápida', 12)" class="bg-white border border-slate-200 p-2.5 rounded-xl text-left hover:border-blue-500 transition-colors flex flex-col justify-between h-14 shadow-sm">
                            <span class="text-[10px] font-bold text-slate-800 truncate block w-full">Cargador Tipo C</span>
                            <span class="text-xs font-black text-blue-600 font-mono">$12.00</span>
                        </button>
                    </div>
                </div>

                <div class="bg-white border border-slate-200 rounded-2xl p-4 shadow-sm space-y-3">
                    <h4 class="text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-1 flex justify-between">
                        <span>Resumen de Venta</span>
                        <span class="font-mono text-slate-500">Nota #001</span>
                    </h4>
                    <div id="desglose-productos-ticket" class="space-y-2 max-h-32 overflow-y-auto font-medium text-xs text-slate-600 no-scrollbar">
                        <p class="text-center text-slate-400 py-4 italic">Ningún artículo en la lista. Toque un producto arriba.</p>
                    </div>

                    <div class="pt-2 border-t border-slate-100 space-y-1.5">
                        <input type="text" id="ticket-cliente" placeholder="Nombre del Cliente (Opcional)" class="w-full bg-slate-50 border border-slate-150 p-2 rounded-xl text-xs font-bold text-slate-800 focus:outline-none">
                        <input type="text" id="ticket-imei" placeholder="IMEI / Nota en Factura" class="w-full bg-slate-50 border border-slate-150 p-2 rounded-xl text-xs font-mono text-slate-800 focus:outline-none">
                    </div>

                    <div class="bg-slate-50 p-3 rounded-xl border border-slate-100 space-y-1.5 font-mono">
                        <div class="flex justify-between items-center text-sm font-black text-slate-900">
                            <span>TOTAL REF:</span>
                            <span id="total-usd" class="text-blue-600 font-black text-base">$0.00</span>
                        </div>
                        <div class="flex justify-between items-center text-[11px] font-bold text-slate-500 border-t border-slate-200/60 pt-1.5">
                            <span>Total Pesos (COP):</span>
                            <span id="total-cop" class="text-amber-600">0 COP</span>
                        </div>
                        <div class="flex justify-between items-center text-[11px] font-bold text-slate-500">
                            <span>Total Bolívares (Bs):</span>
                            <span id="total-bs" class="text-emerald-600">0.00 Bs</span>
                        </div>
                    </div>
                </div>

                <!-- DOS BOTONES DE SALIDA SELECCIONABLES (PDF Y WHATSAPP) -->
                <div class="grid grid-cols-2 gap-2 pt-1">
                    <button onclick="enviarFacturaWhatsAppClienteSimulada()" class="bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-black py-3 rounded-xl shadow-md flex items-center justify-center gap-1.5 uppercase transition-all"><i class="fa-brands fa-whatsapp text-sm"></i> Enviar WhatsApp</button>
                    <button onclick="descargarFacturaPDFSimulada()" class="bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-black py-3 rounded-xl shadow-md flex items-center justify-center gap-1.5 uppercase transition-all"><i class="fa-solid fa-file-pdf text-sm"></i> Descargar PDF</button>
                </div>
                
                <div class="w-full pt-1">
                    <button onclick="alert('🖨️ Despachando formato adaptado a tiras térmicas convencionales y Epson horizontales.')" class="w-full bg-slate-950 text-white text-xs font-black py-3 rounded-xl shadow-md flex items-center justify-center gap-1.5 uppercase"><i class="fa-solid fa-print text-sm"></i> Imprimir Ticket</button>
                </div>
            </div>

            <!-- NAVEGACIÓN INFERIOR -->
            <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-slate-200 h-16 grid grid-cols-4 text-center items-center text-slate-400 z-30">
                <button class="text-blue-600 flex flex-col items-center justify-center gap-1"><i class="fa-solid fa-cash-register text-sm"></i><span class="text-[9px] font-bold uppercase">Facturar</span></button>
                <button onclick="alert('Módulo Inventario: Permite agregar nuevos ítems libres o estructurados de teléfonos (Marca, Modelo, Memoria, IMEI), modificar costos y precios de venta.')" class="flex flex-col items-center justify-center gap-1"><i class="fa-solid fa-box-open text-sm"></i><span class="text-[9px] font-bold uppercase">Inventario</span></button>
                <button onclick="alert('Módulo Gastos: Formulario para egresos del día con selector de moneda.')" class="flex flex-col items-center justify-center gap-1"><i class="fa-solid fa-receipt text-sm"></i><span class="text-[9px] font-bold uppercase">Gastos</span></button>
                <button onclick="alert('Módulo Reportes: Historial de notas, cierres de caja y cambio de clave privada.')" class="flex flex-col items-center justify-center gap-1"><i class="fa-solid fa-chart-pie text-sm"></i><span class="text-[9px] font-bold uppercase">Reportes</span></button>
            </div>
        </div>

    </div>

    <!-- MODAL INFORME WHATSAPP -->
    <div id="modal-whatsapp-nota" class="fixed inset-0 bg-slate-950/90 z-50 p-4 hidden flex items-center justify-center">
        <div class="bg-white text-slate-900 w-full max-w-sm rounded-3xl shadow-2xl overflow-hidden flex flex-col">
            <div class="bg-emerald-600 px-4 py-3 text-white flex justify-between items-center font-bold text-xs uppercase">
                <span><i class="fa-brands fa-whatsapp mr-1 text-sm"></i> Mensaje de Nota Emitida</span>
                <button onclick="document.getElementById('modal-whatsapp-nota').classList.add('hidden')" class="text-white"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="p-4 bg-emerald-50 text-xs font-mono whitespace-pre-wrap leading-relaxed select-all text-left max-h-[45vh] overflow-y-auto" id="whatsapp-nota-content"></div>
            <div class="p-3 bg-gray-50 border-t border-gray-100 flex justify-end">
                <button onclick="document.getElementById('modal-whatsapp-nota').classList.add('hidden')" class="bg-emerald-600 text-white font-black text-xs px-5 py-2 rounded-xl">Entendido</button>
            </div>
        </div>
    </div>


    <script>
        // CONFIGURACIÓN DE PROPIETARIO Y ATRIBUTOS DE SAAS PROTEGIDOS
        let idSeleccionadoActual = null;
        let logoBase64Global = "";
        let diasSimuladosValor = 365;
        let ticketProductos = [];
        let acumuladoUSD = 0;
        let infoClienteAbiertoDinamico = { nombre: "", garantia: "", dias: 365, ownerID: "" };

        function cerrarConfiguracionCliente() {
            document.getElementById('modal-config-master').classList.add('hidden');
            limpiarCamposModalConfig();
        }

        function abrirConfiguracionCliente(id, nombre, rif, tlf, dir, redes, garantia, user, pass, dias) {
            idSeleccionadoActual = id;
            diasSimuladosValor = parseInt(dias) || 365;
            
            document.getElementById('cfg-modal-titulo').innerText = `Configurar: ${nombre}`;
            document.getElementById('cfg-nombre').value = nombre;
            document.getElementById('cfg-rif').value = rif;
            document.getElementById('cfg-tlf').value = tlf;
            document.getElementById('cfg-dir').value = dir;
            document.getElementById('cfg-redes').value = redes;
            document.getElementById('cfg-garantia').value = garantia;
            document.getElementById('cfg-user').value = user;
            document.getElementById('cfg-pass').value = pass;
            
            document.getElementById('cfg-dias-display').innerText = `${diasSimuladosValor} Días`;
            document.getElementById('cfg-link-url').value = `${window.location.href.split('?')[0]}?user=${user}`;
            
            marcarBotonTiempoActivo(diasSimuladosValor);

            const btnBorrar = document.getElementById('cfg-btn-borrar');
            if(id.startsWith('demo-')) {
                btnBorrar.onclick = function() { alert("No se eliminan los perfiles base en la simulación."); };
            } else {
                btnBorrar.onclick = function() { eliminarPerfilNuevoSimulado(id); };
            }

            document.getElementById('modal-config-master').classList.remove('hidden');
        }

        // CONTROLADOR CRÍTICO: SUSTITUYE EL PLAZO EXACTO (EVITA MANIPULACIÓN)
        function asignarDiasSimulador(cantidad, boton) {
            diasSimuladosValor = cantidad;
            document.getElementById('cfg-dias-display').innerText = `${diasSimuladosValor} Días`;
            
            document.querySelectorAll('.tiempo-btn').forEach(btn => {
                btn.className = "tiempo-btn bg-slate-900 border border-slate-800 text-slate-300 text-[10px] py-2 font-bold rounded-lg transition-all";
            });
            boton.className = "tiempo-btn bg-purple-600 border border-purple-500 text-white text-[10px] py-2 font-black rounded-lg transition-all shadow-[0_0_8px_rgba(147,51,234,0.4)]";
        }

        function marcarBotonTiempoActivo(dias) {
            document.querySelectorAll('.tiempo-btn').forEach(btn => {
                btn.className = "tiempo-btn bg-slate-900 border border-slate-800 text-slate-300 text-[10px] py-2 font-bold rounded-lg transition-all";
                if(btn.innerText.includes('1 Mes') && dias === 30) btn.className = "tiempo-btn bg-purple-600 border border-purple-500 text-white text-[10px] py-2 font-black rounded-lg transition-all";
                if(btn.innerText.includes('6 Meses') && dias === 180) btn.className = "tiempo-btn bg-purple-600 border border-purple-500 text-white text-[10px] py-2 font-black rounded-lg transition-all";
                if(btn.innerText.includes('1 Año') && dias === 365) btn.className = "tiempo-btn bg-purple-600 border border-purple-500 text-white text-[10px] py-2 font-black rounded-lg transition-all";
            });
        }

        function copiarLinkPortapapelesDemo() {
            const inputLink = document.getElementById('cfg-link-url');
            inputLink.select();
            document.execCommand('copy');
            alert(`🔒 ¡Enlace Copiado!`);
        }

        function abrirModalCrearPerfil() {
            idSeleccionadoActual = "nuevo-" + new Date().getTime();
            diasSimuladosValor = 365;
            
            document.getElementById('cfg-modal-titulo').innerText = "➕ Crear Nuevo Perfil";
            document.getElementById('cfg-nombre').value = "";
            document.getElementById('cfg-rif').value = "";
            document.getElementById('cfg-tlf').value = "";
            document.getElementById('cfg-dir').value = "";
            document.getElementById('cfg-redes').value = "";
            document.getElementById('cfg-garantia').value = "Garantía de 2 meses por defectos de fábrica.";
            document.getElementById('cfg-user').value = "comercio_nuevo";
            document.getElementById('cfg-user').disabled = false;
            document.getElementById('cfg-user').className = "w-full bg-slate-950 border border-slate-800 p-2.5 rounded-xl text-xs font-bold text-white font-mono focus:outline-none";
            document.getElementById('cfg-pass').value = "12345";
            
            document.getElementById('cfg-dias-display').innerText = "365 Días";
            document.getElementById('cfg-link-url').value = `${window.location.href.split('?')[0]}?user=comercio_nuevo`;
            marcarBotonTiempoActivo(365);
            
            document.getElementById('cfg-user').onkeyup = function() {
                const cleanUser = this.value.trim().toLowerCase().replace(/[^a-z0-9]/g, '');
                document.getElementById('cfg-link-url').value = `${window.location.href.split('?')[0]}?user=${cleanUser}`;
            };

            document.getElementById('modal-config-master').classList.remove('hidden');
        }

        function guardarDatosClienteSimulados() {
            const nombre = document.getElementById('cfg-nombre').value.trim();
            const user = document.getElementById('cfg-user').value.trim().toLowerCase().replace(/[^a-z0-9]/g, '');
            const rif = document.getElementById('cfg-rif').value.trim();
            const tlf = document.getElementById('cfg-tlf').value.trim();
            const dir = document.getElementById('cfg-dir').value.trim();
            const redes = document.getElementById('cfg-redes').value.trim();
            const garantia = document.getElementById('cfg-garantia').value.trim();
            const pass = document.getElementById('cfg-pass').value.trim();

            if(!nombre || !user) return alert("Complete nombre y usuario.");

            if(idSeleccionadoActual.startsWith('demo-')) {
                const tarjeta = document.getElementById(`card-${idSeleccionadoActual}`);
                tarjeta.querySelector('h3').innerText = nombre;
                document.getElementById(`label-dias-card-${idSeleccionadoActual}`).innerText = `${diasSimuladosValor} Días`;
                
                const labelStatus = document.getElementById(`label-status-card-${idSeleccionadoActual}`);
                if(diasSimuladosValor <= 30) {
                    labelStatus.className = "text-red-400 font-bold uppercase text-[10px]";
                    labelStatus.innerText = "Por Vencer";
                    tarjeta.querySelector('.absolute span').className = "w-2.5 h-2.5 rounded-full bg-red-500 animate-pulse";
                } else {
                    labelStatus.className = "text-emerald-400 font-bold";
                    labelStatus.innerText = "Activo";
                    tarjeta.querySelector('.absolute span').className = "w-2.5 h-2.5 rounded-full bg-emerald-400";
                }
                
                tarjeta.querySelector('button').setAttribute('onclick', `abrirConfiguracionCliente('${idSeleccionadoActual}', '${nombre}', '${rif}', '${tlf}', '${dir}', '${redes}', '${garantia.replace(/'/g, "\\'")}', '${user}', '${pass}', '${diasSimuladosValor}')`);
                tarjeta.querySelectorAll('button')[1].setAttribute('onclick', `forzarEntradaClienteDirecta('${nombre}', '${garantia.replace(/'/g, "\\'")}', ${diasSimuladosValor}, '${user}')`);
            } else {
                const grid = document.getElementById('mosaico-clientes-grid');
                const nuevaCardHTML = document.createElement('div');
                nuevaCardHTML.id = `card-${idSeleccionadoActual}`;
                nuevaCardHTML.className = "bg-slate-900 border border-slate-800/80 rounded-3xl p-5 flex flex-col justify-between hover:border-blue-500/40 transition-all group relative overflow-hidden";
                
                const colorLuz = diasSimuladosValor <= 30 ? 'bg-red-500 animate-pulse' : 'bg-emerald-400';
                const statusTexto = diasSimuladosValor <= 30 ? 'Por Vencer' : 'Activo';
                const statusColorClase = diasSimuladosValor <= 30 ? 'text-red-400 font-bold uppercase text-[10px]' : 'text-emerald-400 font-bold';
                const imgTag = logoBase64Global ? `<img src="${logoBase64Global}" class="w-full h-full object-contain">` : `<i class="fa-solid fa-store text-xl text-purple-400"></i>`;

                nuevaCardHTML.innerHTML = `
                    <div class="absolute top-4 right-4 flex items-center gap-1.5 z-10">
                        <span class="w-2.5 h-2.5 rounded-full ${colorLuz}"></span>
                    </div>
                    <div>
                        <div class="w-14 h-14 bg-slate-950 border border-slate-800 rounded-2xl flex items-center justify-center p-2 mb-3 overflow-hidden shadow-inner">
                            ${imgTag}
                        </div>
                        <h3 class="font-black text-white text-base tracking-tight group-hover:text-blue-400 transition-colors">${nombre}</h3>
                        <p class="text-[9px] text-slate-500 font-bold font-mono tracking-wider mt-0.5 uppercase">ID: ${user}</p>
                        <div class="mt-3 space-y-1 bg-slate-950/60 p-3 rounded-xl border border-slate-850 text-xs font-medium text-slate-400">
                            <p class="flex justify-between font-mono"><span class="text-slate-500">Suscripción:</span> <span class="${diasSimuladosValor <= 30 ? 'text-red-400 font-black animate-pulse' : 'text-slate-300 font-bold'}" id="label-dias-card-${idSeleccionadoActual}">${diasSimuladosValor} Días</span></p>
                            <p class="flex justify-between font-mono"><span class="text-slate-500">Estado:</span> <span class="${statusColorClase}" id="label-status-card-${idSeleccionadoActual}">${statusTexto}</span></p>
                        </div>
                    </div>
                    <div class="mt-5 pt-3 border-t border-slate-800/60 flex gap-2">
                        <button onclick="abrirConfiguracionCliente('${idSeleccionadoActual}', '${nombre}', '${rif}', '${tlf}', '${dir}', '${redes}', '${garantia.replace(/'/g, "\\'")}', '${user}', '${pass}', '${diasSimuladosValor}')" class="w-1/2 bg-slate-800 text-slate-200 text-xs font-bold py-2.5 rounded-xl">Configurar</button>
                        <button onclick="forzarEntradaClienteDirecta('${nombre}', '${garantia.replace(/'/g, "\\'")}', ${diasSimuladosValor}, '${user}')" class="w-1/2 bg-blue-600 text-white text-xs font-black py-2.5 rounded-xl uppercase tracking-wider">Entrar</button>
                    </div>`;
                
                grid.insertBefore(nuevaCardHTML, grid.lastElementChild);
                const contadorGlobal = document.getElementById('global-clientes-count');
                contadorGlobal.innerText = parseInt(contadorGlobal.innerText) + 1;
            }
            cerrarConfiguracionCliente();
        }

        function eliminarPerfilNuevoSimulado(id) {
            if(confirm("¿Deseas eliminar este perfil de prueba?")) {
                document.getElementById(`card-${id}`).remove();
                const cG = document.getElementById('global-clientes-count');
                cG.innerText = Math.max(0, parseInt(cG.innerText) - 1);
                cerrarConfiguracionCliente();
            }
        }

        function dispararContratoWhatsAppSimulado() {
            const nombre = document.getElementById('cfg-nombre').value || "[Nombre del Comercio]";
            const user = document.getElementById('cfg-user').value || "[Usuario]";
            const pass = document.getElementById('cfg-pass').value || "[Contraseña]";
            const link = document.getElementById('cfg-link-url').value;
            
            const textoContrato = `📱 * shadow-lg TUCOCEL C.A. — ACTIVACIÓN DE SISTEMA*\n\nEstimado cliente de *${nombre}*, por medio de la presente le informamos que su _Sistema de Gestión y Facturación Administrativa_ ha sido registrado exitosamente en nuestros servidores de Google Firebase.\n\n🌐 *Link de Ingreso:* ${link}\n👤 *Usuario:* ${user}\n🔑 *Contraseña:* ${pass}\n⏱️ *Plan contratado:* ${diasSimuladosValor} Días\n\n⚠️ *RECUERDE NUESTRAS REGLAS DE ORO:*\n1. El usuario es el único responsable legal por los datos e inventarios registrados.\n2. Sistema interno de emisión de notas de entrega sin valor fiscal.\n3. El acceso se mantendrá activo exclusivamente durante el plazo prepagado.\n\n¡Gracias por su confianza! 🚀🔒`;
            
            document.getElementById('whatsapp-preview-content').innerText = textoContrato;
            document.getElementById('modal-whatsapp-preview').classList.remove('hidden');
        }

        // Enrutador de URL e inicialización de Propietario (Owner ID)
        window.onload = function() {
            const urlParams = new URLSearchParams(window.location.search);
            const userParam = urlParams.get('user');
            
            if(userParam) {
                document.getElementById('vista-master-admin').classList.add('hidden');
                document.getElementById('vista-entorno-cliente').classList.remove('hidden');
                
                let nombreComercio = "Comercio Registrado";
                let garantiaTexto = "Garantía de 2 meses por defectos de fábrica.";
                let diasQuedan = 365;

                if(userParam === 'citymovil') {
                    nombreComercio = "City Móvil";
                    document.getElementById('login-logo-dinamico').innerHTML = `<i class="fa-solid fa-mobile-screen"></i>`;
                } else if(userParam === 'donluis') {
                    nombreComercio = "Frigorífico Don Luis";
                    garantiaTexto = "No se aceptan cambios en productos cárnicos.";
                    diasQuedan = 12;
                    document.getElementById('login-logo-dinamico').innerHTML = `<i class="fa-solid fa-shop"></i>`;
                }

                infoClienteAbiertoDinamico = { nombre: nombreComercio, garantia: garantiaTexto, dias: diasQuedan, ownerID: userParam };
                document.getElementById('login-titulo-dinamico').innerText = nombreComercio;
            }
        };

        function forzarEntradaClienteDirecta(nombre, garantia, dias, ownerID) {
            infoClienteAbiertoDinamico = { nombre: nombre, garantia: garantia, dias: dias, ownerID: ownerID };
            document.getElementById('login-titulo-dinamico').innerText = nombre;
            
            document.getElementById('vista-master-admin').classList.add('hidden');
            document.getElementById('vista-entorno-cliente').classList.remove('hidden');
        }

        function desbloquearPantallaFacturacionReal() {
            document.getElementById('cli-bloque-login').classList.add('hidden');
            document.getElementById('cli-bloque-sistema').classList.remove('hidden');
            
            document.getElementById('cli-panel-nombre').innerText = infoClienteAbiertoDinamico.nombre;
            document.getElementById('cli-panel-garantia-txt').innerText = infoClienteAbiertoDinamico.garantia;
            
            const yDisplay = document.getElementById('cli-panel-dias-conteo');
            const iconReloj = document.getElementById('cli-panel-icon-reloj');
            const bannerAlerta = document.getElementById('banner-alerta-vencimiento');
            const bannerIcono = document.getElementById('banner-alerta-icono');
            const bannerTitulo = document.getElementById('banner-alerta-titulo');
            const bannerDesc = document.getElementById('banner-alerta-desc');
            const statusBox = document.getElementById('contenedor-status-reloj');
            
            yDisplay.innerText = `${infoClienteAbiertoDinamico.dias} Días`;
            
            // LÓGICA DE ALERTA DINÁMICA DE TEMPORIZACIÓN DE SUSCRIPCIÓN (BLOQUEO INALTERABLE)
            if(infoClienteAbiertoDinamico.dias <= 5) {
                // Alerta Crítica Roja (Faltan 5 días o menos)
                yDisplay.className = "text-red-600 font-black animate-pulse";
                iconReloj.className = "fa-solid fa-hourglass-half text-red-500 animate-spin";
                statusBox.className = "bg-red-100 border border-red-300 px-2.5 py-1 rounded-xl flex items-center gap-1 text-[10px] font-mono font-bold animate-bounce";
                
                bannerAlerta.className = "bg-red-50 border border-red-200 text-red-900 rounded-2xl p-4 flex items-center gap-3 shadow-md";
                bannerIcono.className = "fa-solid fa-circle-xmark text-red-600 text-xl animate-pulse";
                bannerTitulo.innerText = "🔴 RIESGO DE SUSPENSIÓN INMEDIATA";
                bannerDesc.innerText = `Atención: Su licencia administrativa expira en ${infoClienteAbiertoDinamico.dias} días. El módulo POS se bloqueará al llegar a 0. Comuníquese urgentemente con Tucocel C.A.`;
                bannerAlerta.classList.remove('hidden');
            } 
            else if(infoClienteAbiertoDinamico.dias <= 15) {
                // Alerta Preventiva Naranja (Faltan entre 6 y 15 días)
                yDisplay.className = "text-orange-600 font-black animate-pulse";
                iconReloj.className = "fa-solid fa-hourglass-half text-orange-500";
                statusBox.className = "bg-orange-50 border border-orange-200 px-2.5 py-1 rounded-xl flex items-center gap-1 text-[10px] font-mono font-bold";
                
                bannerAlerta.className = "bg-orange-50 border border-orange-200 text-orange-900 rounded-2xl p-4 flex items-center gap-3 shadow-inner";
                bannerIcono.className = "fa-solid fa-triangle-exclamation text-orange-600 text-xl";
                bannerTitulo.innerText = "🔶 AVISO DE VENCIMIENTO DE MEMBRESÍA";
                bannerDesc.innerText = `Le recordamos que a su suscripción le quedan ${infoClienteAbiertoDinamico.dias} días de cobertura administrativa. Genere el pago de renovación para evitar interrupciones de servicio.`;
                bannerAlerta.classList.remove('hidden');
            } 
            else {
                // Estado Normal Activo
                yDisplay.className = "text-slate-700 font-black";
                iconReloj.className = "fa-solid fa-hourglass-half text-amber-500";
                statusBox.className = "bg-gray-100 border border-gray-200 px-2.5 py-1 rounded-xl flex items-center gap-1 text-[10px] font-mono font-bold";
                bannerAlerta.classList.add('hidden');
            }
            
            document.body.className = "bg-slate-50 text-slate-800 min-h-screen transition-all duration-300";
        }

        function regresarAlMasterControlAdmin() {
            document.getElementById('cli-bloque-sistema').classList.add('hidden');
            document.getElementById('cli-bloque-login').classList.remove('hidden');
            document.getElementById('vista-entorno-cliente').classList.add('hidden');
            
            window.history.pushState({}, document.title, window.location.pathname);
            
            document.body.className = "bg-slate-950 text-slate-100 min-h-screen transition-all duration-300";
            document.getElementById('vista-master-admin').classList.remove('hidden');
            ticketProductos = [];
            calcularTotalesSimulados();
        }

        function agregarAlTicketSimulado(nombre, precio) {
            // Protección defensiva matemática contra manipulación del HTML
            let valorValidado = parseFloat(precio);
            if (isNaN(valorValidado) || valorValidado <= 0) return;
            
            ticketProductos.push({ nombre: nombre, precio: valorValidado });
            calcularTotalesSimulados();
        }

        function calcularTotalesSimulados() {
            const contenedor = document.getElementById('desglose-productos-ticket');
            const tCOP = parseFloat(document.getElementById('tasa-cop').value) || 3900;
            const tBs = parseFloat(document.getElementById('tasa-bs').value) || 40;
            
            if(ticketProductos.length === 0) {
                contenedor.innerHTML = `<p class="text-center text-slate-400 py-4 italic">Ningún artículo en la lista. Toque un producto arriba.</p>`;
                acumuladoUSD = 0;
                document.getElementById('total-usd').innerText = "$0.00";
                document.getElementById('total-cop').innerText = "0 COP";
                document.getElementById('total-bs').innerText = "0.00 Bs";
                return;
            }

            contenedor.innerHTML = "";
            acumuladoUSD = 0;
            ticketProductos.forEach((prod) => {
                acumuladoUSD += prod.precio;
                const pDiv = document.createElement('div');
                pDiv.className = "flex justify-between items-center py-1 border-b border-slate-100";
                pDiv.innerHTML = `<span>1x ${prod.nombre}</span> <span class="font-mono font-bold">$${prod.precio.toFixed(2)}</span>`;
                contenedor.appendChild(pDiv);
            });

            document.getElementById('total-usd').innerText = `$${acumuladoUSD.toFixed(2)}`;
            document.getElementById('total-cop').innerText = `${(acumuladoUSD * tCOP).toLocaleString('es-ES')} COP`;
            document.getElementById('total-bs').innerText = `${(acumuladoUSD * tBs).toFixed(2)} Bs`;
        }

        function enviarFacturaWhatsAppClienteSimulada() {
            if(ticketProductos.length === 0) return alert("Cargue algún producto.");
            const cliente = document.getElementById('ticket-cliente').value.trim() || "Cliente General";
            const imei = document.getElementById('ticket-imei').value.trim() || "N/A";
            const tCOP = document.getElementById('tasa-cop').value;
            const tBs = document.getElementById('tasa-bs').value;
            
            let cuerpoText = "";
            ticketProductos.forEach(p => { cuerpoText += `▪️ 1x ${p.nombre} — $${p.precio.toFixed(2)}\n`; });

            const textoWhatsAppFactura = `🛍️ *${infoClienteAbiertoDinamico.nombre.toUpperCase()} — NOTA DE ENTREGA*\n\n👤 *Cliente:* ${cliente}\n📱 *IMEI / Detalle:* ${imei}\n📅 *Fecha:* ${new Date().toLocaleDateString()}\n\n*DESGLOSE:*\n${cuerpoText}\n💰 *TOTALES MULTIMONEDA:*\n💵 REF: $${acumuladoUSD.toFixed(2)}\n🇨🇴 COP: ${(acumuladoUSD * tCOP).toLocaleString('es-ES')} COP\n🇻🇪 Bs: ${(acumuladoUSD * tBs).toFixed(2)} Bs\n\n⚠️ *GARANTÍA:*\n${infoClienteAbiertoDinamico.garantia}\n\n🔒 _Comprobante interno administrativo sin valor fiscal._\n\n⚙️ _Infraestructura protegida por Tucocel C.A. y @publionlinemk_`;

            document.getElementById('whatsapp-nota-content').innerText = textoWhatsAppFactura;
            document.getElementById('modal-whatsapp-nota').classList.remove('hidden');
        }

        // GENERADOR DE ARCHIVO PDF INALTERABLE DESDE EL NAVEGADOR
        function descargarFacturaPDFSimulada() {
            if(ticketProductos.length === 0) return alert("Cargue algún producto para procesar el PDF.");
            
            const cliente = document.getElementById('ticket-cliente').value.trim() || "Cliente General";
            const imei = document.getElementById('ticket-imei').value.trim() || "N/A";
            const tCOP = document.getElementById('tasa-cop').value;
            const tBs = document.getElementById('tasa-bs').value;
            
            alert(`🔒 ¡Generando Documento PDF Inalterable de forma exitosa! \n\nEstableciendo cabeceras de protección de datos para la Distribuidora de origen [ID: ${infoClienteAbiertoDinamico.ownerID}].\n\nEl archivo final se descargará en su dispositivo bajo la firma de Nota de Entrega Privada sin valor fiscal.`);
        }

        function previewImageDemo(e) {
            const file = e.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function(event) {
                logoBase64Global = event.target.result;
                document.getElementById('cfg-logo-preview').src = logoBase64Global;
                document.getElementById('cfg-logo-preview').classList.remove('hidden');
                document.getElementById('cfg-logo-placeholder').classList.add('hidden');
            };
            reader.readAsDataURL(file);
        }

        function limpiarCamposModalConfig() {
            document.getElementById('cfg-logo-preview').src = "";
            document.getElementById('cfg-logo-preview').classList.add('hidden');
            document.getElementById('cfg-logo-placeholder').classList.remove('hidden');
            logoBase64Global = "";
            document.getElementById('cfg-user').disabled = true;
            document.getElementById('cfg-user').className = "w-full bg-slate-950/50 border border-slate-850 p-2.5 rounded-xl text-xs font-bold text-slate-500 font-mono cursor-not-allowed";
            document.getElementById('cfg-user').onkeyup = null;
        }
    </script>
</body>
</html>
